generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String       @id @default(uuid())
  email               String       @unique
  name                String?      @unique
  createdAt           DateTime     @default(now())
  auditLogs           AuditLog[]
  invitationsReceived Invitation[] @relation("InvitationsReceived")
  invitationsSent     Invitation[] @relation("InvitationsSent")
  cases               Case[]       @relation("CaseInvestigators")
}

model Invitation {
  id        String   @id @default(uuid())
  caseId    String
  inviterId String
  inviteeId String
  role      String   @default("VIEWER")
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  invitee   User     @relation("InvitationsReceived", fields: [inviteeId], references: [id])
  inviter   User     @relation("InvitationsSent", fields: [inviterId], references: [id])

  @@unique([caseId, inviteeId])
}

model Case {
  id           String        @id @default(uuid())
  title        String
  description  String?
  status       String        @default("ACTIVE")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  aiAnalysis   Json?
  auditLogs    AuditLog[]
  documents    Document[]
  edges        Edge[]
  invitations  Invitation[]
  nodes        Node[]
  chatMessages ChatMessage[]
  news         News[]
  users        User[]        @relation("CaseInvestigators")
}

model ChatMessage {
  id           String   @id @default(uuid())
  content      String
  senderId     String   @map("sender_id")
  senderName   String   @map("sender_name")
  senderAvatar String?  @map("sender_avatar")
  caseId       String   @map("case_id")
  createdAt    DateTime @default(now()) @map("created_at")
  case         Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

model Document {
  id          String   @id @default(uuid())
  caseId      String
  title       String
  sourceUrl   String?
  storageKey  String?
  contentHash String?
  fileType    String
  nodeId      String?  @unique
  createdAt   DateTime @default(now())
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  node        Node?    @relation(fields: [nodeId], references: [id])
}

model Node {
  id        String    @id @default(uuid())
  caseId    String
  type      NodeType
  label     String
  content   String?
  positionX Float     @default(0)
  positionY Float     @default(0)
  latitude  Float?
  longitude Float?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  document  Document?
  edgesOut  Edge[]    @relation("FromNode")
  edgesIn   Edge[]    @relation("ToNode")
  case      Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  locationEvents LocationEvent[]
}

model LocationEvent {
  id        String   @id @default(cuid())
  entityId  String
  latitude  Float
  longitude Float
  timestamp DateTime
  source    String
  node      Node     @relation(fields: [entityId], references: [id], onDelete: Cascade)
}

model Edge {
  id               String   @id @default(uuid())
  caseId           String
  sourceId         String
  targetId         String
  relationshipType String
  createdAt        DateTime @default(now())
  case             Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  source           Node     @relation("FromNode", fields: [sourceId], references: [id])
  target           Node     @relation("ToNode", fields: [targetId], references: [id])

  @@unique([sourceId, targetId, relationshipType])
}

model AuditLog {
  id        String   @id @default(uuid())
  caseId    String
  userId    String
  action    String
  icon      String   @default("zap")
  createdAt DateTime @default(now())
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model News {
  id          String   @id @default(cuid())
  caseId      String
  title       String
  summary     String
  content     String?
  source      String
  url         String?
  imageUrl    String?
  publishedAt DateTime @default(now())
  sentiment   Float?
  createdAt   DateTime @default(now())
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@map("news")
}

enum NodeType {
  DOCUMENT
  SUMMARY
  CONJECTURE
  INVESTIGATION_TASK
  ENTITY_PERSON
  ENTITY_ORG
  ENTITY_LOCATION
  EVENT
}
