generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String       @id @default(uuid())
  email               String       @unique
  name                String?      @unique
  cases               Case[]       @relation("CaseInvestigators")
  invitationsSent     Invitation[] @relation("InvitationsSent")
  invitationsReceived Invitation[] @relation("InvitationsReceived")
  createdAt           DateTime     @default(now())
  auditLogs           AuditLog[]
}

model Invitation {
  id        String @id @default(uuid())
  caseId    String
  case      Case   @relation(fields: [caseId], references: [id])
  inviterId String
  inviter   User   @relation("InvitationsSent", fields: [inviterId], references: [id])
  inviteeId String
  invitee   User   @relation("InvitationsReceived", fields: [inviteeId], references: [id])
  role      String @default("VIEWER") // EDITOR, VIEWER
  status    String @default("PENDING") // PENDING, ACCEPTED, REJECTED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([caseId, inviteeId]) // Prevent duplicate invites for same case
}

model Case {
  id          String  @id @default(uuid())
  title       String
  description String?
  status      String  @default("ACTIVE") // ACTIVE, RESOLVED, ARCHIVED

  users     User[]     @relation("CaseInvestigators")
  documents Document[]
  nodes     Node[] // Knowledge Graph Nodes
  edges     Edge[] // Knowledge Graph Edges

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  invitations Invitation[]
  auditLogs   AuditLog[]
  chatMessages ChatMessage[]
}

model ChatMessage {
  id            String   @id @default(uuid())
  content       String
  senderId     String    @map("sender_id")
  senderName   String    @map("sender_name")
  senderAvatar String?   @map("sender_avatar")
  caseId       String    @map("case_id")
  case          Case     @relation(fields: [caseId], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("chat_messages")
}

model Document {
  id     String @id @default(uuid())
  caseId String
  case   Case   @relation(fields: [caseId], references: [id])

  title       String
  sourceUrl   String?
  storageKey  String? // S3 path
  contentHash String? // For deduplication
  fileType    String // PDF, TXT, LINK, IMAGE

  // Backlink to its corresponding Node in the Graph
  nodeId String? @unique
  node   Node?   @relation(fields: [nodeId], references: [id])

  createdAt DateTime @default(now())
}

enum NodeType {
  DOCUMENT
  SUMMARY
  CONJECTURE
  INVESTIGATION_TASK
  ENTITY_PERSON
  ENTITY_ORG
  ENTITY_LOCATION
  EVENT
}

model Node {
  id     String @id @default(uuid())
  caseId String
  case   Case   @relation(fields: [caseId], references: [id])

  type    NodeType
  label   String // Display name in React Flow
  content String? // Rich text, markdown, or JSON metadata (AI output)

  // Real-time canvas positioning
  positionX Float @default(0)
  positionY Float @default(0)

  // Links
  document Document? // Optional relation if type=DOCUMENT

  edgesOut Edge[] @relation("FromNode")
  edgesIn  Edge[] @relation("ToNode")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Edge {
  id     String @id @default(uuid())
  caseId String
  case   Case   @relation(fields: [caseId], references: [id])

  sourceId String
  targetId String
  source   Node   @relation("FromNode", fields: [sourceId], references: [id])
  target   Node   @relation("ToNode", fields: [targetId], references: [id])

  relationshipType String // 'summarized_from', 'mentions', 'suggests', 'supports', 'contradicts'

  createdAt DateTime @default(now())

  @@unique([sourceId, targetId, relationshipType])
}

model AuditLog {
  id        String   @id @default(uuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  action    String
  icon      String   @default("zap")

  createdAt DateTime @default(now())
}

